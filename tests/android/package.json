{
  "name": "costco-saver-android-e2e",
  "version": "1.0.0",
  "description": "Android E2E testing suite for Costco Saver Pro",
  "scripts": {
    "test:android": "wdio run wdio.conf.js",
    "test:android:debug": "wdio run wdio.conf.js --logLevel verbose",
    "test:android:auth": "wdio run wdio.conf.js --spec specs/authentication.android.js",
    "test:android:receipt": "wdio run wdio.conf.js --spec specs/receipt-upload.android.js",
    "test:android:tracking": "wdio run wdio.conf.js --spec specs/price-tracking.android.js",
    "test:android:notifications": "wdio run wdio.conf.js --spec specs/notifications.android.js",
    "test:android:e2e": "wdio run wdio.conf.js --spec specs/e2e-flow.android.js"
  },
  "keywords": [
    "appium",
    "webdriver",
    "android",
    "e2e",
    "testing"
  ],
  "author": "Costco Saver Pro Team",
  "license": "MIT",
  "devDependencies": {
    "@wdio/appium-service": "^8.24.0",
    "@wdio/cli": "^8.24.0",
    "@wdio/local-runner": "^8.24.0",
    "@wdio/mocha-framework": "^8.24.0",
    "@wdio/spec-reporter": "^8.24.0",
    "appium": "^2.0.0",
    "appium-uiautomator2-driver": "^2.0.0",
    "chai": "^4.3.10",
    "wdio-wait-for": "^2.2.6"
  }
}
